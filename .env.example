# ─── Groq LLM Provider (required) ────────────────────────────────────────────
# Obtain from https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model configuration
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3

# ─── Hugging Face Dataset ─────────────────────────────────────────────────────
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# ─── Local Data Cache ─────────────────────────────────────────────────────────
# Path where the preprocessed dataset is cached locally (relative to project root)
DATA_CACHE_PATH=./data/restaurants.parquet
